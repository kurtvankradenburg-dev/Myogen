# ── AI (Groq — free at console.groq.com) ─────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase Auth ─────────────────────────────────────────────────────────
# Create a project at console.firebase.google.com
# Enable Authentication → Google + Email/Password providers
# Add http://localhost:5173 to Authorized Domains
VITE_FIREBASE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxxxx
# Enable Google Analytics (format: G-XXXXXXXXXX) — optional
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── PayPal (REQUIRED for server-side payment verification) ────────────────
# Get from developer.paypal.com → My Apps & Credentials → your app → Secret
# Without this, premium activation will fail (payments can't be verified)
PAYPAL_CLIENT_ID=AblZ4yl5au3t1cJDheYA0Dyl55sHj1sIaXJZfQu0XM8X3twE3wb2B-USrj1A3FLgsdCvmZd_bu2-O53P
PAYPAL_CLIENT_SECRET=your-paypal-client-secret-here
